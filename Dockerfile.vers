FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy project files
COPY . /app/

# Initialize submodules
RUN git config --global --add safe.directory /app && \
    git config --global --add safe.directory /app/shapez && \
    git submodule update --init --recursive || true

# Install Python dependencies for hermes-agent
RUN pip install --no-cache-dir -e . 2>/dev/null || \
    pip install --no-cache-dir -r requirements.txt 2>/dev/null || \
    pip install --no-cache-dir openai fire python-dotenv pyyaml httpx || true

# Install additional dependencies for shapez UI
RUN pip install --no-cache-dir flask flask-cors

# Expose port for shapez UI
EXPOSE 8080

# Default command - start the shapez web server
CMD ["python", "/app/shapez/server.py", "--host", "0.0.0.0", "--port", "8080"]
